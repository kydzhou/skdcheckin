# 复制为 .env 后填写（不要提交 .env 到 Git）
# 获取方式见 README.md

# 森空岛 Token，多账号用英文分号分隔
SKYLAND_TOKEN=你的token1;你的token2

# 是否推送通知（需配置飞书或 Server 酱其一）
SKYLAND_NOTIFY=false

# 飞书群机器人 Webhook（推荐：建一个只有自己的群，添加自定义机器人）
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# 若机器人启用了签名校验，填写 Secret
# FEISHU_SECRET=xxxxxxxx
# 仅推送签到成功的记录（true/false，默认 true）
# FEISHU_NOTIFY_SUCCESS_ONLY=true

# Server 酱 SendKey（可选）
# SERVERCHAN_SENDKEY=
